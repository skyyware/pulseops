{
  "name": "pulseops",
  "version": "1.0.0",
  "private": false,
  "type": "module",
  "description": "A small C++/WebAssembly and React monitoring cockpit proof of concept.",
  "scripts": {
    "predev": "npm run build:wasm",
    "dev": "vite --host 0.0.0.0",
    "build:wasm": "node scripts/build-wasm.mjs",
    "typecheck": "tsc -b",
    "build": "npm run build:wasm && npm run typecheck && vite build",
    "test:unit": "vitest run",
    "preview": "vite preview --host 0.0.0.0",
    "check": "npm run build && npm run test:unit",
    "deploy:stage": "npm run build && node scripts/deploy-stage.mjs"
  },
  "dependencies": {
    "lucide-react": "^0.511.0",
    "react": "^19.1.0",
    "react-dom": "^19.1.0"
  },
  "devDependencies": {
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "typescript": "^6.0.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8"
  }
}
